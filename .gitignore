# ---- 依赖 ----
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ---- Next.js 构建产物 ----
/.next/
/out/
/build
next-env.d.ts.timestamp

# ---- 运行时 / 调试 ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- 本地环境变量 ----
.env
.env*.local
