# ---- 依赖 ----
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ---- Next.js 构建产物 ----
/.next/
/out/
/build
next-env.d.ts.timestamp

# ---- 运行时 / 调试 ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- 本地环境变量（任何 .env 变体都不入库，模板除外）----
.env
.env.*
!.env.example

# ---- 本地持久化数据（运行时生成，不入库）----
/data/**

# ---- 原始接口抓包 / 样例（含真实密钥，勿入库）----
# docs/ 下只允许 .md 文档入库，抓包不论后缀（txt/json/har/…）与层级一律拦下
/docs/**
!/docs/**/
!/docs/**/*.md

# ---- 工具 / 缓存 ----
.playwright-mcp/
.turbo/
*.tsbuildinfo

# ---- 系统 / 编辑器 ----
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
