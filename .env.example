# 复制为 .env 并填入真实值（.env 已被 gitignore，不会入库）
# naci 平台 Base URL
NACI_BASE_URL=https://open.naci-tech.com
# naci new-api 兼容端点的 Bearer token（个人设置页「生成令牌」获取）
NACI_TOKEN=your-naci-bearer-token
# 默认管理员登录密钥（首次 seed 时写入；留空则自动随机生成并打印到日志）
ADMIN_ACCESS_KEY=your-admin-login-key
# PostgreSQL 密码（docker compose 中 db 服务使用；本地开发直连时也用它拼 DATABASE_URL）
POSTGRES_PASSWORD=change-me-strong-password

# 本地非 Docker 开发可显式指定（compose 部署会自动注入 db 主机名）
# DATABASE_URL=postgres://keyload:change-me-strong-password@localhost:5432/keyload
