# 复制为 .env 并填入真实值（.env 已被 gitignore，不会入库）
NACI_BASE_URL=https://open.naci-tech.com

# naci 账号（后端登录拿 session，用于 admin-hub 全部操作）
NACI_USERNAME=your-naci-username
NACI_PASSWORD=your-naci-password

# 旧 new-api 兼容端点 Bearer token（可选；转向 admin-hub 后可留空）
NACI_TOKEN=

# 本系统默认管理员登录密钥（留空则首次启动随机生成并打印到日志）
ADMIN_ACCESS_KEY=your-admin-login-key

# PostgreSQL 密码
POSTGRES_PASSWORD=change-me-strong-password
